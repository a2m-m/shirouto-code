#!/usr/bin/env python3
import os
import sys
import subprocess
import re
import urllib.request
import urllib.error
import json

def run_command(cmd, shell=False):
    if isinstance(cmd, str) and not shell:
        import shlex
        cmd = shlex.split(cmd)
    result = subprocess.run(cmd, shell=shell, capture_output=True, text=True)
    return result

def get_diff_text():
    # 1. ワークスペース上で現在の PR を取得 (gh pr view)
    pr_number = None
    github_ref = os.environ.get("GITHUB_REF", "")
    if github_ref.startswith("refs/pull/"):
        pr_number = github_ref.split("/")[2]
        
    if not pr_number:
        res = run_command("gh pr view --json number -q .number")
        if res.returncode == 0:
            pr_number = res.stdout.strip()
            
    if pr_number:
        res = run_command(f"gh pr diff {pr_number}")
        if res.returncode == 0 and res.stdout.strip():
            return res.stdout
            
    # 2. PRが取得できなければローカルの origin/mainからの差分
    res = run_command("git diff origin/main...HEAD")
    if res.returncode == 0 and res.stdout.strip():
        return res.stdout
        
    # 3. それでも無ければ現在のワーキングツリーの差分
    res = run_command("git diff HEAD")
    if res.returncode == 0:
        return res.stdout
        
    return ""

def get_ai_review():
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        print("GEMINI_API_KEY is not set. Skipping real AI review.")
        sys.exit(0)
        
    diff_text = get_diff_text()
    if not diff_text.strip():
        print("No diff found. Skipping review.")
        sys.exit(0)
        
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={api_key}"
    
    prompt = f"""
あなたは強力なコードレビュワー（QA/Architect）です。以下のコード差分をレビューし、問題点があれば教育的なフィードバックをJSON形式で提供してください。
JSON形式のスキーマは以下の通りです。JSON以外は出力しないでください。問題が特にない場合でも、何らかの指摘（NITなど）を行うか、ダミーの回答をしてください。

```json
{{
  "Severity": "BLOCKER|HIGH|MEDIUM|LOW|NIT",
  "Finding": "問題の概要",
  "Why": "なぜそれが問題なのか、教育的な解説",
  "Fix direction": "修正の方向性",
  "Example": "修正例のコード。マークダウンのブロックを使用（省略可）",
  "Learn more": "参考となるURLやキーワード（省略可）"
}}
```

Diff:
```diff
{diff_text}
```
"""
    
    data = {"contents": [{"parts": [{"text": prompt}]}]}
    req = urllib.request.Request(
        url,
        data=json.dumps(data).encode("utf-8"),
        headers={"Content-Type": "application/json"}
    )
    
    try:
        with urllib.request.urlopen(req) as response:
            result = json.loads(response.read().decode("utf-8"))
            text = result["candidates"][0]["content"]["parts"][0]["text"]
            
            # Print raw AI output to logs for debugging (only in Actions where things are quiet otherwise)
            if os.environ.get("GITHUB_ACTIONS") == "true":
                print(f"Raw AI Output: {text}")
                
            text = text.strip()
            block_match = re.search(r'```json\n(.*?)\n```', text, re.DOTALL)
            if block_match:
                text = block_match.group(1).strip()
            else:
                match = re.search(r'\{[\s\S]*?\}', text)
                if match:
                    text = match.group(0)
                    
            return json.loads(text)
    except urllib.error.URLError as e:
        print(f"Failed to call Gemini API: {e}")
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'))
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Failed to parse JSON from Gemini API: {e}")
        # Try to print the raw text if possible, though it might fail if text is undefined here.
        sys.exit(1)

def parse_ai_response(response_data):
    # This function is now just ensuring default values since response_data is expected to be a dict
    data = {
        "Severity": "LOW",
        "Finding": "",
        "Why": "",
        "Fix direction": "",
        "Example": "",
        "Learn more": ""
    }
    
    if isinstance(response_data, dict):
        for key in data.keys():
            if key in response_data:
                data[key] = response_data[key]
            # Handle possible lowercase keys from JSON if the LLM ignores the schema casing
            elif key.lower() in response_data:
                data[key] = response_data[key.lower()]
                
    return data

def format_pr_comment(parsed_data):
    if not parsed_data.get("Finding"):
        return None # 指摘がない場合
        
    comment = f"### 🤖 AI Guardrail Review\n\n"
    comment += f"- **Severity**: {parsed_data.get('Severity', 'LOW')}\n"
    comment += f"- **Finding**: {parsed_data.get('Finding', '')}\n"
    comment += f"- **Why**: {parsed_data.get('Why', '')}\n"
    comment += f"- **Fix direction**: {parsed_data.get('Fix direction', '')}\n"
    
    example = parsed_data.get('Example', '')
    if example:
        if not example.startswith('```'):
            comment += f"- **Example**:\n```\n{example}\n```\n"
        else:
            comment += f"- **Example**:\n{example}\n"
            
    learn_more = parsed_data.get('Learn more', '')
    if learn_more:
        comment += f"- **Learn more**: {learn_more}\n"
        
    return comment

def main():
    gh_token = os.environ.get("GITHUB_TOKEN")
    if not gh_token:
        print("GITHUB_TOKEN is not set. Assuming local run, skipping PR comment posting.")
        
    # Get real AI output based on diff
    ai_output = get_ai_review()
    
    # Parse output
    parsed_data = parse_ai_response(ai_output)
    
    # Format comment
    comment_body = format_pr_comment(parsed_data)
    
    if not comment_body:
        print("No findings from Guardrail. Exiting successfully.")
        sys.exit(0)
        
    print("Parsed Guardrail Response:")
    print("--------------------------")
    print(comment_body)
    print("--------------------------")
    
    if gh_token:
        # Determine PR number
        pr_number = None
        github_ref = os.environ.get("GITHUB_REF", "")
        if github_ref.startswith("refs/pull/"):
            pr_number = github_ref.split("/")[2]
            
        if not pr_number:
            res = run_command("gh pr view --json number -q .number")
            if res.returncode == 0:
                pr_number = res.stdout.strip()
                
        if pr_number:
            import tempfile
            fd, tmp_path = tempfile.mkstemp(suffix=".md")
            with os.fdopen(fd, "w") as f:
                f.write(comment_body)
                
            comment_cmd = ["gh", "pr", "comment", str(pr_number), "-F", tmp_path]
            print(f"Posting comment: gh pr comment {pr_number} -F {tmp_path}")
            res = subprocess.run(comment_cmd, capture_output=True, text=True)
            if res.returncode != 0:
                print(f"Failed to post PR comment. {res.stderr}")
                
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        else:
            print("Could not determine PR number. Skipping commenting.")

    # Apply blocking policy
    severity = parsed_data.get("Severity", "LOW").upper()
    if severity in ["BLOCKER", "HIGH"]:
        print(f"::error::Guardrail found issues with severity {severity}. Please review the PR comments.")
        sys.exit(1)
    else:
        print(f"Guardrail check passed with severity {severity} (No string blocking required).")
        sys.exit(0)

if __name__ == "__main__":
    main()

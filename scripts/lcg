#!/usr/bin/env python3
import os
import sys
import subprocess
import re
import tempfile
import urllib.request
import urllib.error
import json


def run_command(cmd, shell=False):
    if isinstance(cmd, str) and not shell:
        import shlex
        cmd = shlex.split(cmd)
    result = subprocess.run(cmd, shell=shell, capture_output=True, text=True)
    return result

def get_diff_text():
    # 1. ワークスペース上で現在の PR を取得 (gh pr view)
    pr_number = None
    github_ref = os.environ.get("GITHUB_REF", "")
    if github_ref.startswith("refs/pull/"):
        pr_number = github_ref.split("/")[2]
        
    if not pr_number:
        res = run_command("gh pr view --json number -q .number")
        if res.returncode == 0:
            pr_number = res.stdout.strip()
            
    if pr_number:
        res = run_command(f"gh pr diff {pr_number}")
        if res.returncode == 0 and res.stdout.strip():
            return res.stdout
        else:
            print("Fallback: get_diff_text 'gh pr diff' failed or empty.")
    else:
        print("Fallback: get_diff_text could not determine PR number.")
            
    # 2. PRが取得できなければローカルの origin/mainからの差分
    res = run_command("git diff origin/main...HEAD")
    if res.returncode == 0 and res.stdout.strip():
        return res.stdout
    else:
        print("Fallback: get_diff_text 'git diff origin/main...HEAD' failed or empty.")
        
    # 3. それでも無ければ現在のワーキングツリーの差分
    res = run_command("git diff HEAD")
    if res.returncode == 0 and res.stdout.strip():
        return res.stdout
    else:
        print("Fallback: get_diff_text 'git diff HEAD' failed or empty.")
        
    return ""

def get_config():
    config = {'policy': {'max_diff_warning': 1200}}
    try:
        with open('os-template.yml', 'r') as f:
            content = f.read()
            match = re.search(r'max_diff_warning:\s*(\d+)', content)
            if match:
                 config['policy']['max_diff_warning'] = int(match.group(1))
    except Exception as e:
        print(f"Warning: Failed to parse max_diff_warning from os-template.yml: {e}")
    return config

def is_huge_diff(config):
    max_diff_warning = config.get('policy', {}).get('max_diff_warning', 1200)
    
    # Calculate PR diff size
    res = run_command("git diff origin/main...HEAD --shortstat")
    if res.returncode != 0:
        return False
        
    stat_output = res.stdout.strip()
    # e.g. " 3 files changed, 50 insertions(+), 20 deletions(-)"
    insertions = 0
    deletions = 0
    
    ins_match = re.search(r'(\d+) insertion', stat_output)
    if ins_match:
        insertions = int(ins_match.group(1))
        
    del_match = re.search(r'(\d+) deletion', stat_output)
    if del_match:
        deletions = int(del_match.group(1))
        
    total_diff = insertions + deletions
    print(f"Diff size: {total_diff} lines (Threshold: {max_diff_warning})")
    
    return total_diff > max_diff_warning

def get_ai_lcg_mock(is_huge):
    # Mocking AI response mapping to the expected dict
    if is_huge:
        return {
            "Summary": "巨大な変更があったため要約を優先します。多数のファイルの追加変更が行われました。",
            "Deep Dive": [],
            "Quiz": [
                "巨大なコミットを責務ごとに分割するための基準は何ですか？",
                "この変更による影響範囲を抑えるために、CIでどのテストが重要になりますか？"
            ],
            "Explore next": "巨大なPRを避けるための設計の分割方法について"
        }
    else:
        return {
            "Summary": "設定ファイルの追加とLCGワークフローの骨格が整備されました。",
            "Deep Dive": [
                "`.github/workflows/lcg.yml`: OSのフィーチャーフラグに基づいて動作を切り替える設計パターンです。"
            ],
            "Quiz": [
                "`features.lcg` が `false` の場合にワークフローがスキップされる仕組みはどのように実装されていますか？",
                "Github Actions における `contents: write` 権限の用途は何ですか？"
            ],
            "Explore next": "AIがソースコードをコンテキスト付きで解釈するための最適なプロンプト設計について"
        }

def generate_learning_content(is_huge, diff_text):
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        print("GEMINI_API_KEY is not set. Using mock for local testing.")
        return get_ai_lcg_mock(is_huge)

    if not diff_text.strip():
        print("No diff found. Skipping AI content generation.")
        return None

    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={api_key}"
    
    huge_instruction = ""
    if is_huge:
        huge_instruction = "今回の変更は非常に大きいため、要約（Summary）を特に重視し、その他の項目は簡潔にまとめてください。\\n"
        if len(diff_text) > 50000:
            diff_text = diff_text[:50000] + "\n... (Diff truncated due to size limit)"

    prompt = f"""
あなたは優秀なプログラミング講師です。以下のコード差分を解析し、学習コンテンツをJSON形式で生成してください。
{huge_instruction}

以下のJSONスキーマに従い、JSONのみを出力してください（Markdownのコードブロックなども許容しますが、中身は純粋なJSONとして生成してください）。
空の配列や空文字列も適宜使用してください。

```json
{{
  "Summary": "変更の全体的な要約",
  "Deep Dive": ["詳細な技術的解説1", "詳細な技術的解説2"],
  "Quiz": ["変更内容に関する理解度確認クイズ1", "理解度確認クイズ2"],
  "Explore next": "この変更に関連して次に学ぶべきトピックや関連技術"
}}
```

Diff:
```diff
{diff_text}
```
"""

    data = {"contents": [{"parts": [{"text": prompt}]}]}
    req = urllib.request.Request(
        url,
        data=json.dumps(data).encode("utf-8"),
        headers={"Content-Type": "application/json"}
    )
    
    try:
        with urllib.request.urlopen(req) as response:
            result = json.loads(response.read().decode("utf-8"))
            try:
                text = result["candidates"][0]["content"]["parts"][0]["text"]
            except (KeyError, IndexError, TypeError) as e:
                print(f"Failed to extract text from Gemini response structure: {result}")
                return get_ai_lcg_mock(is_huge)
                
            text = text.strip()
            if text.startswith("```json"):
                text = text[7:]
            if text.startswith("```"):
                text = text[3:]
            if text.endswith("```"):
                text = text[:-3]
            text = text.strip()
            return json.loads(text)
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.reason}\n{e.read().decode('utf-8')}")
        return get_ai_lcg_mock(is_huge)
    except Exception as e:
        print(f"Failed to call Gemini API or parse response: {e}")
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'))
        return get_ai_lcg_mock(is_huge)

def parse_ai_response(response_data):
    data = {
        "Summary": "",
        "Deep Dive": [],
        "Quiz": [],
        "Explore next": ""
    }
    
    if isinstance(response_data, dict):
        for key in data.keys():
            if key in response_data:
                data[key] = response_data[key]
            elif key.lower() in response_data:
                data[key] = response_data[key.lower()]
    else:
        print(f"Warning: AI response is not a valid dict: {response_data}")
                
    return data

def format_pr_comment(parsed_data):
    # PRコメントには Summary + Quiz を投稿
    comment = "### 📚 Learning Content Generator\n\n"
    
    if parsed_data.get("Summary"):
        comment += f"**📝 Summary**\n{parsed_data['Summary']}\n\n"
        
    if parsed_data.get("Quiz"):
        comment += "**🧠 Quiz (理解度確認)**\n"
        for i, q in enumerate(parsed_data["Quiz"], 1):
            comment += f"{i}. {q}\n"
        comment += "\n"
        
    if parsed_data.get("Explore next"):
        comment += f"**🚀 Explore next**\n{parsed_data['Explore next']}\n"
        
    return comment

def format_asset_doc(parsed_data):
    # 資産化用のLong Form (Deep Dive含む)
    doc = "# Learning Content: PR Updates\n\n"
    
    if parsed_data.get("Summary"):
        doc += f"## Summary\n{parsed_data['Summary']}\n\n"
        
    if parsed_data.get("Deep Dive"):
        doc += "## Deep Dive\n"
        for item in parsed_data["Deep Dive"]:
             doc += f"- {item}\n"
        doc += "\n"
        
    if parsed_data.get("Quiz"):
        doc += "## Quiz\n"
        for i, q in enumerate(parsed_data["Quiz"], 1):
            doc += f"{i}. {q}\n"
        doc += "\n"
        
    if parsed_data.get("Explore next"):
        doc += f"## Explore next\n{parsed_data['Explore next']}\n"
        
    return doc

def commit_asset(doc_content):
    asset_dir = "docs/learning/commits"
    if not os.path.exists(asset_dir):
        # Spec says create docs/learning/commits/, trigger on existing .gitkeep, 
        # but let's just make sure it creates it and commits.
        os.makedirs(asset_dir, exist_ok=True)
        
    # Get short commit hash of HEAD to use as filename
    res = run_command("git rev-parse --short HEAD")
    if res.returncode == 0:
        hash_val = res.stdout.strip()
    else:
        hash_val = "unknown"
        
    filename = f"{asset_dir}/{hash_val}.md"
    with open(filename, "w") as f:
        f.write(doc_content)
        
    print(f"Created learning material asset: {filename}")
    
    # Configure git inside GH actions
    if os.environ.get("GITHUB_ACTIONS") == "true":
         run_command('git config user.name "github-actions[bot]"')
         run_command('git config user.email "github-actions[bot]@users.noreply.github.com"')
    
    # Commit and push
    run_command(f'git add {filename}')
    res_commit = run_command(f'git commit -m "docs: auto-generate learning content for {hash_val}"')
    
    if res_commit.returncode == 0:
        print("Committed learning material successfully.")
        
        # Determine branch to push to
        push_ref = "HEAD"
        github_head_ref = os.environ.get("GITHUB_HEAD_REF")
        if github_head_ref:
            push_ref = f"HEAD:refs/heads/{github_head_ref}"
            
        res_push = run_command(f'git push origin {push_ref}')
        if res_push.returncode != 0:
            print(f"Warning: Push failed. Might need to adjust branch protection. {res_push.stderr}")
        else:
            print("Pushed learning material successfully.")
    else:
        print("Nothing to commit for learning material (file might already exist and is unchanged).")

def main():
    gh_token = os.environ.get("GITHUB_TOKEN")
    if not gh_token:
        print("GITHUB_TOKEN is not set. Assuming local test run.")
        
    config = get_config()
    huge_diff = is_huge_diff(config)
    
    diff_text = get_diff_text()
    
    # Get AI output
    ai_output = generate_learning_content(huge_diff, diff_text)
    if not ai_output:
        print("Exiting as no AI output was generated.")
        sys.exit(0)
    
    # Parse output
    parsed_data = parse_ai_response(ai_output)
    
    # Format and Post PR Comment
    comment_body = format_pr_comment(parsed_data)
    print("----- PR COMMENT -----")
    print(comment_body)
    print("----------------------")
    
    if gh_token:
        # Determine PR number
        pr_number = None
        github_ref = os.environ.get("GITHUB_REF", "")
        if github_ref.startswith("refs/pull/"):
            pr_number = github_ref.split("/")[2]
            
        if not pr_number:
            res = run_command("gh pr view --json number -q .number")
            if res.returncode == 0:
                pr_number = res.stdout.strip()
                
        if pr_number:
            fd, tmp_path = tempfile.mkstemp(suffix=".md")
            with os.fdopen(fd, "w") as f:
                f.write(comment_body)
                
            comment_cmd = ["gh", "pr", "comment", str(pr_number), "-F", tmp_path]
            print(f"Posting comment: gh pr comment {pr_number} -F {tmp_path}")
            res = subprocess.run(comment_cmd, capture_output=True, text=True)
            if res.returncode != 0:
                print(f"Failed to post PR comment. {res.stderr}")
                
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        else:
            print("Could not determine PR number. Skipping PR comment posting.")

    # Save and commit Long Form Doc
    doc_body = format_asset_doc(parsed_data)
    commit_asset(doc_body)
    
    sys.exit(0)

if __name__ == "__main__":
    main()

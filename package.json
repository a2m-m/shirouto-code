{
  "name": "shirouto-code",
  "displayName": "シロートコード",
  "description": "ターミナル操作を翻訳・解説するサイドカー拡張",
  "version": "0.0.1",
  "publisher": "a2m-m",
  "repository": {
    "type": "git",
    "url": "https://github.com/a2m-m/shirouto-code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "enabledApiProposals": ["terminalDataWriteEvent"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shirouto-code.openPanel",
        "title": "シロートコード: パネルを開く"
      },
      {
        "command": "shirouto-code.startPtySession",
        "title": "シロートコード: PTY 翻訳セッションを起動"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shirouto-code",
          "title": "シロートコード",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "shirouto-code": [
        {
          "type": "webview",
          "id": "shirouto-code.sidecarPanel",
          "name": "シロートコード"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "title": "シロートコード翻訳セッション",
          "id": "shirouto-code.translationSession"
        }
      ]
    },
    "configuration": {
      "title": "シロートコード",
      "properties": {
        "shirouto-code.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API キー（Google AI Studio から取得）"
        },
        "shirouto-code.customDangerCommands": {
          "type": "array",
          "default": [],
          "description": "ユーザー定義の危険コマンドルール。組み込みルールに追加されます。",
          "items": {
            "type": "object",
            "required": ["command", "level"],
            "properties": {
              "command": {
                "type": "string",
                "description": "危険と判定するコマンド名（例: kubectl）"
              },
              "level": {
                "type": "string",
                "enum": ["low", "medium", "high"],
                "description": "危険度レベル"
              },
              "warning": {
                "type": "string",
                "description": "解説カードに表示する警告メッセージ（省略可）"
              }
            }
          }
        },
        "shirouto-code.enableAiSend": {
          "type": "boolean",
          "default": true,
          "description": "ターミナル出力を Gemini AI に送信して翻訳する。オフにすると AI への送信を停止します。"
        },
        "shirouto-code.customSecretPatterns": {
          "type": "array",
          "default": [],
          "description": "ユーザー定義の秘密情報検知パターン（正規表現）。マッチした文字列は AI 送信前に [MASKED] に置換されます。",
          "items": {
            "type": "string",
            "description": "正規表現パターン（例: mytoken-[a-z0-9]+）"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.24.0"
  }
}

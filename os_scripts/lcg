#!/usr/bin/env python3
import os
import sys
import subprocess
import re
import tempfile
import urllib.request
import urllib.error
import json
from datetime import datetime

# Add scripts/lib to path so config can be imported securely
_SCRIPTS_DIR = os.path.dirname(os.path.abspath(__file__))
_REPO_ROOT = os.path.dirname(_SCRIPTS_DIR)
_OS_TEMPLATE = os.path.join(_REPO_ROOT, "os-template.yml")
sys.path.insert(0, os.path.join(_SCRIPTS_DIR, 'lib'))
import config as custom_config


def run_command(cmd, shell=False):
    if isinstance(cmd, str) and not shell:
        import shlex
        cmd = shlex.split(cmd)
    result = subprocess.run(cmd, shell=shell, capture_output=True, text=True)
    return result

def get_pr_number():
    github_ref = os.environ.get("GITHUB_REF", "")
    if github_ref.startswith("refs/pull/"):
        return github_ref.split("/")[2]
        
    res = run_command(["gh", "pr", "view", "--json", "number", "-q", ".number"])
    if res.returncode == 0:
        return res.stdout.strip()
    return None

def get_diff_text(pr_number):
    # 1. ワークスペース上で現在の PR を取得 (gh pr view)
    if pr_number:
        res = run_command(["gh", "pr", "diff", str(pr_number)])
        if res.returncode == 0 and res.stdout.strip():
            return res.stdout
        else:
            print("Fallback: get_diff_text 'gh pr diff' failed or empty.")
    else:
        print("Fallback: get_diff_text could not determine PR number.")
            
    # 2. PRが取得できなければローカルの origin/mainからの差分
    res = run_command(["git", "diff", "origin/main...HEAD"])
    if res.returncode == 0 and res.stdout.strip():
        return res.stdout
    else:
        print("Fallback: get_diff_text 'git diff origin/main...HEAD' failed or empty.")
        
    # 3. それでも無ければ現在のワーキングツリーの差分
    res = run_command(["git", "diff", "HEAD"])
    if res.returncode == 0 and res.stdout.strip():
        return res.stdout
    else:
        print("Fallback: get_diff_text 'git diff HEAD' failed or empty.")
        
    return ""

def get_config():
    # Attempt to load the python config module
    try:
        config_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', 'os-template.yml')
        config = custom_config.load_config(config_path)
    except Exception as e:
        print(f"Warning: Failed to parse os-template.yml using config.py: {e}")
        config = {'policy': {'max_diff_warning': 1200}}
        
    return config

def get_ai_settings():
    provider = custom_config.get_value(_OS_TEMPLATE, "ai.provider") or "gemini"
    model = custom_config.get_value(_OS_TEMPLATE, "ai.model") or "gemini-2.5-flash"
    return provider, model


def is_huge_diff(config, diff_text):
    max_diff_warning = config.get('policy', {}).get('max_diff_warning', 1200)
    
    lines_changed = len([l for l in diff_text.splitlines() if l.startswith(('+', '-')) and not l.startswith(('+++', '---'))])
    print(f"Diff size: {lines_changed} lines (Threshold: {max_diff_warning})")
    
    return lines_changed > max_diff_warning

def get_ai_lcg_mock(is_huge, diff_text=""):
    files_changed = re.findall(r'^diff --git a/(.*?) b/', diff_text, re.MULTILINE)
    file_info = f" ({', '.join(files_changed[:3])} 等)" if files_changed else ""
    
    topic_mock = "misc-updates"
    if files_changed:
        first_file_name_with_ext = files_changed[0].split('/')[-1]
        # 拡張子を除去 (例: "my_module.py" -> "my_module", "LICENSE" -> "LICENSE")
        filename_base = first_file_name_with_ext.rsplit('.', 1)[0] \
                        if '.' in first_file_name_with_ext else first_file_name_with_ext
        
        # 不適切な文字をハイフンに置換し、小文字化
        clean_filename = re.sub(r'[^a-zA-Z0-9-]', '-', filename_base).strip('-').lower()
        
        # 生成されたトピックが空でなければ使用、そうでなければデフォルト
        topic_mock = f"update-{clean_filename}" if clean_filename else "misc-updates"

    # Mocking AI response mapping to the expected dict
    if is_huge:
        return {
            "Topic": "large-refactor",
            "Summary": f"巨大な変更があったため要約を優先します。多数のファイルの追加変更が行われました。{file_info}",
            "Deep Dive": [],
            "Quiz": [
                "巨大なコミットを責務ごとに分割するための基準は何ですか？",
                "この変更による影響範囲を抑えるために、CIでどのテストが重要になりますか？"
            ],
            "Explore next": "巨大なPRを避けるための設計の分割方法について"
        }
    else:
        return {
            "Topic": topic_mock,
            "Summary": f"設定ファイルの追加とLCGワークフローの骨格が整備されました。{file_info}",
            "Deep Dive": [
                "`.github/workflows/lcg.yml`: OSのフィーチャーフラグに基づいて動作を切り替える設計パターンです。"
            ],
            "Quiz": [
                "`features.lcg` が `false` の場合にワークフローがスキップされる仕組みはどのように実装されていますか？",
                "Github Actions における `contents: write` 権限の用途は何ですか？"
            ],
            "Explore next": "AIがソースコードをコンテキスト付きで解釈するための最適なプロンプト設計について"
        }

def generate_learning_content(is_huge, diff_text):
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        if os.environ.get("GITHUB_ACTIONS") == "true":
            print("Error: GEMINI_API_KEY is required when LCG is enabled.")
            sys.exit(1)
        print("GEMINI_API_KEY is not set. Using mock for local testing.")
        return get_ai_lcg_mock(is_huge, diff_text)

    if not diff_text.strip():
        print("No diff found. Skipping AI content generation.")
        return None

    provider, model = get_ai_settings()
    if provider != "gemini":
        print(f"Error: Unsupported ai.provider '{provider}'. Only 'gemini' is currently supported.")
        sys.exit(1)

    url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent"
    
    huge_instruction = ""
    if is_huge:
        huge_instruction = "今回の変更は非常に大きいため、要約（Summary）を特に重視し、その他の項目は簡潔にまとめてください。\n"
        
    if len(diff_text) > 40000:
        diff_text = diff_text[:40000].rsplit('\n', 1)[0] + "\n... (Diff truncated due to size limit)"

    safe_diff_text = diff_text.replace("```", "\\`\\`\\`").replace("</diff>", "<\\/diff>")

    prompt = f"""
あなたは優秀なプログラミング講師です。以下のコード差分を解析し、学習コンテンツをJSON形式で生成してください。
{huge_instruction}

以下のJSONスキーマに従い、JSONのみを出力してください（Markdownのコードブロックなども許容しますが、中身は純粋なJSONとして生成してください）。
空の配列や空文字列も適宜使用してください。

差分データは <diff> と </diff> のタグで囲んで提供します。

```json
{{
  "Topic": "変更内容を表す短い英語のケバブケース文字列 (例: add-user-auth, fix-db-connection, etc.)",
  "Summary": "変更の全体的な要約",
  "Deep Dive": ["詳細な技術的解説1", "詳細な技術的解説2"],
  "Quiz": ["変更内容に関する理解度確認クイズ1", "理解度確認クイズ2"],
  "Explore next": "この変更に関連して次に学ぶべきトピックや関連技術"
}}
```

<diff>
{safe_diff_text}
</diff>
"""

    data = {"contents": [{"parts": [{"text": prompt}]}]}
    req = urllib.request.Request(
        url,
        data=json.dumps(data).encode("utf-8"),
        headers={
            "Content-Type": "application/json",
            "x-goog-api-key": api_key
        }
    )
    
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            result = json.loads(response.read().decode("utf-8"))
            try:
                text = result["candidates"][0]["content"]["parts"][0]["text"]
            except (KeyError, IndexError, TypeError) as e:
                print(f"Failed to extract text from Gemini response structure: {result}")
                return get_ai_lcg_mock(is_huge, diff_text)
                
            text = text.strip()
            block_match = re.search(r'```json\n(.*?)\n```', text, re.DOTALL)
            if block_match:
                text = block_match.group(1).strip()
            else:
                match = re.search(r'\{[\s\S]*?\}', text)
                if match:
                    text = match.group(0)
            return json.loads(text)
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.reason}\n{e.read().decode('utf-8')}")
        return get_ai_lcg_mock(is_huge, diff_text)
    except Exception as e:
        print(f"Failed to call Gemini API or parse response: {e}")
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'))
        return get_ai_lcg_mock(is_huge, diff_text)

def parse_ai_response(response_data):
    data = {
        "Topic": "misc-updates",
        "Summary": "",
        "Deep Dive": [],
        "Quiz": [],
        "Explore next": ""
    }
    
    if isinstance(response_data, dict):
        for key in data.keys():
            val = response_data.get(key)
            if val is None:
                val = response_data.get(key.lower())
            
            if key in ["Topic", "Summary", "Explore next"]:
                if isinstance(val, str):
                    data[key] = val
                elif val is not None:
                    data[key] = str(val)
            elif key in ["Deep Dive", "Quiz"]:
                if isinstance(val, list):
                    data[key] = [str(x) for x in val]
                elif val is not None:
                    data[key] = [str(val)]
    else:
        print(f"Warning: AI response is not a valid dict: {response_data}")
                
    return data

def format_pr_comment(parsed_data):
    # PRコメントには Summary + Quiz を投稿
    comment = "### 📚 Learning Content Generator\n\n"
    
    if parsed_data.get("Summary"):
        comment += f"**📝 Summary**\n{parsed_data['Summary']}\n\n"
        
    if parsed_data.get("Quiz"):
        comment += "**🧠 Quiz (理解度確認)**\n"
        for i, q in enumerate(parsed_data["Quiz"], 1):
            comment += f"{i}. {q}\n"
        comment += "\n"
        
    if parsed_data.get("Explore next"):
        comment += f"**🚀 Explore next**\n{parsed_data['Explore next']}\n"
        
    return comment

def format_asset_doc(parsed_data, context_name):
    # 資産化用のLong Form (Deep Dive含む)
    doc = f"# Learning Content: {context_name}\n\n"
    
    topic = parsed_data.get("Topic", "misc-updates")
    doc += f"**Topic**: {topic}\n\n"

    if parsed_data.get("Summary"):
        doc += f"## Summary\n{parsed_data['Summary']}\n\n"
        
    if parsed_data.get("Deep Dive"):
        doc += "## Deep Dive\n"
        for item in parsed_data["Deep Dive"]:
             doc += f"- {item}\n"
        doc += "\n"
        
    if parsed_data.get("Quiz"):
        doc += "## Quiz\n"
        for i, q in enumerate(parsed_data["Quiz"], 1):
            doc += f"{i}. {q}\n"
        doc += "\n"
        
    if parsed_data.get("Explore next"):
        doc += f"## Explore next\n{parsed_data['Explore next']}\n"
        
    return doc

def commit_asset(doc_content, context_prefix, topic, hash_val):
    # Sanitize topic for filename (allow alphanumeric and hyphens)
    safe_topic = re.sub(r'[^a-zA-Z0-9-]', '-', topic).strip('-').lower()
    safe_topic = safe_topic[:50].strip('-')
    if not safe_topic:
        safe_topic = "misc-updates"
        
    date_str = datetime.now().strftime('%Y-%m-%d')
    filename_base = f"{date_str}-{context_prefix}-{safe_topic}-{hash_val}.md"
    
    asset_dir = "docs/learning/commits"
    if not os.path.exists(asset_dir):
        # Spec says create docs/learning/commits/, trigger on existing .gitkeep, 
        # but let's just make sure it creates it and commits.
        os.makedirs(asset_dir, exist_ok=True)
        
    filename = f"{asset_dir}/{filename_base}"
    with open(filename, "w") as f:
        f.write(doc_content)
        
    print(f"Created learning material asset: {filename}")
    
    # Configure git inside GH actions
    if os.environ.get("GITHUB_ACTIONS") == "true":
         run_command(["git", "config", "user.name", "github-actions[bot]"])
         run_command(["git", "config", "user.email", "github-actions[bot]@users.noreply.github.com"])
    
    # Commit and push
    run_command(["git", "add", filename])
    res_commit = run_command(["git", "commit", "-m", f"docs: auto-generate learning content for {context_prefix} ({topic})"])
    
    if res_commit.returncode == 0:
        print("Committed learning material successfully.")
        
        # Determine branch to push to
        push_ref = "HEAD"
        github_head_ref = os.environ.get("GITHUB_HEAD_REF")
        if github_head_ref:
            push_ref = f"HEAD:refs/heads/{github_head_ref}"
            
        res_push = run_command(["git", "push", "origin", push_ref])
        if res_push.returncode != 0:
            print(f"Warning: Push failed. Might need to adjust branch protection. {res_push.stderr}")
        else:
            print("Pushed learning material successfully.")
    else:
        print(f"Commit skipped or failed: {res_commit.stderr.strip() or 'no changes to commit'}")

def main():
    gh_token = os.environ.get("GITHUB_TOKEN")
    if not gh_token:
        print("GITHUB_TOKEN is not set. Assuming local test run.")
        
    pr_number = get_pr_number()
    diff_text = get_diff_text(pr_number)
    
    config = get_config()
    huge_diff = is_huge_diff(config, diff_text)
    
    # Get AI output
    ai_output = generate_learning_content(huge_diff, diff_text)
    if not ai_output:
        print("Exiting as no AI output was generated.")
        sys.exit(0)
    
    # Parse output
    parsed_data = parse_ai_response(ai_output)
    
    # Format and Post PR Comment
    comment_body = format_pr_comment(parsed_data)
    print("----- PR COMMENT -----")
    print(comment_body)
    print("----------------------")
    
    if gh_token:
        if pr_number:
            fd, tmp_path = tempfile.mkstemp(suffix=".md")
            with os.fdopen(fd, "w") as f:
                f.write(comment_body)
                
            comment_cmd = ["gh", "pr", "comment", str(pr_number), "-F", tmp_path]
            print(f"Posting comment: gh pr comment {pr_number} -F {tmp_path}")
            res = subprocess.run(comment_cmd, capture_output=True, text=True)
            if res.returncode != 0:
                print(f"Failed to post PR comment. {res.stderr}")
                
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
        else:
            print("Could not determine PR number. Skipping PR comment posting.")

    # Save and commit Long Form Doc
    res_hash = run_command(["git", "rev-parse", "--short", "HEAD"])
    hash_val = res_hash.stdout.strip() if res_hash.returncode == 0 else f"unknown-{datetime.now().strftime('%Y%m%d%H%M%S')}"
    
    context_name = f"PR #{pr_number}" if pr_number else f"Commit {hash_val}"
    context_prefix = f"PR-{pr_number}" if pr_number else f"Commit-{hash_val}"
    doc_body = format_asset_doc(parsed_data, context_name)
    
    topic = parsed_data.get("Topic", "misc-updates")
    commit_asset(doc_body, context_prefix, topic, hash_val)
    
    sys.exit(0)

if __name__ == "__main__":
    main()
